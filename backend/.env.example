# App Configuration
APP_NAME=Liga EDUmind
DEBUG=True
SECRET_KEY=CHANGE_ME_IN_PRODUCTION
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
RATE_LIMIT_ENABLED=true
RATE_LIMIT_STORAGE_URL=redis://localhost:6379/1
AUTH_ACCESS_COOKIE_NAME=edumind_access_token
AUTH_REFRESH_COOKIE_NAME=edumind_refresh_token
AUTH_COOKIE_SECURE=true
AUTH_COOKIE_SAMESITE=lax
AUTH_COOKIE_DOMAIN=
AUTH_COOKIE_PATH=/
AUTH_ALLOW_REFRESH_TOKEN_IN_BODY=false
AUTHENTIK_ENABLED=false
AUTHENTIK_ISSUER_URL=https://auth.edumind.es/application/o/liga-edumind/
AUTHENTIK_CLIENT_ID=
AUTHENTIK_CLIENT_SECRET=
# Alternativa recomendada en produccion con secreto montado como fichero:
# AUTHENTIK_CLIENT_SECRET_FILE=/run/secrets/liga_edumind_authentik_client_secret
AUTHENTIK_REDIRECT_URI=https://liga.edumind.es/api/v1/auth/oidc/callback
AUTHENTIK_SCOPES=openid profile email
AUTHENTIK_AUTO_PROVISION=false
AUTHENTIK_ALLOWED_EMAIL_DOMAINS=edumind.es,losmundosedufis.com
SECURITY_HEADERS_ENABLED=true
SECURITY_CSP=default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'self' https://*.edumind.es https://*.losmundosedufis.com; form-action 'self' https://auth.edumind.es; upgrade-insecure-requests
SECURITY_PERMISSIONS_POLICY=accelerometer=(), autoplay=(), camera=(), display-capture=(), geolocation=(), gyroscope=(), microphone=(), payment=(), usb=()
SECURITY_CROSS_ORIGIN_OPENER_POLICY=same-origin-allow-popups
SECURITY_REFERRER_POLICY=strict-origin-when-cross-origin
SECURITY_FRAME_OPTIONS=SAMEORIGIN
SECURITY_HSTS_SECONDS=63072000
SECURITY_HSTS_INCLUDE_SUBDOMAINS=true
SECURITY_HSTS_PRELOAD=true
FREE_PLAN_MAX_LEAGUES=3
LEAGUE_GRANDFATHERING_CUTOFF=2026-06-30T23:59:59Z

# Database
DATABASE_URL=postgresql+asyncpg://liga_edumind:liga_edumind@localhost:5432/liga_edumind

# Safety guard for scripts (optional)
# Comma-separated hostnames considered production. Scripts will refuse unless ALLOW_PROD_DB=1.
PROD_DB_HOSTS=localhost,127.0.0.1
ALLOW_PROD_DB=0

# Redis
REDIS_URL=redis://localhost:6379/0

# Email (SMTP2GO)
DISCORD_WEBHOOK_URL=
DISCORD_INCLUDE_CONTACT_EMAIL=false
MAIL_SERVER=mail.smtp2go.com
MAIL_PORT=587
MAIL_USERNAME=noreply@losmundosedufis.com
MAIL_PASSWORD=CHANGE_ME
MAIL_FROM=noreply@losmundosedufis.com
MAIL_FROM_NAME=Liga EDUmind

# Storage
UPLOAD_DIR=/app/static/uploads
MAX_UPLOAD_SIZE_MB=5
MAX_REQUEST_SIZE_MB=8
SUBMISSION_POLICY_NOTICE_VERSION=2026-04-02
# Optional comma-separated extra blocked terms for public game sheets.
SUBMISSION_BLOCKLIST_TERMS=
# Optional secret for irreversible per-day fingerprints on public submissions.
SUBMISSION_FINGERPRINT_SECRET=

# Ops Metrics security
METRICS_ALLOWED_IPS=127.0.0.1,::1
METRICS_TOKEN=

# CORS
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Matomo Analytics (optional)
MATOMO_BASE_URL=https://analytics.losmundosedufis.com
MATOMO_SITE_ID=4

# Nextcloud (optional evidences copy)
NEXTCLOUD_WEBDAV_URL=
NEXTCLOUD_USERNAME=
NEXTCLOUD_PASSWORD=
NEXTCLOUD_EVIDENCIAS_PATH=Evidencias_Liga
# Legacy/global uploads stay restricted to explicit identities (emails and/or user codes).
NEXTCLOUD_ALLOWED_EMAIL=luisvilela@live.com
NEXTCLOUD_ALLOWED_IDENTITIES=luisvilela@live.com,luisvilela
